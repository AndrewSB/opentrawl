#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
bin_dir="$repo_root/.dev/bin"

# One build incantation everywhere: C SQLite (mattn/go-sqlite3) with FTS5.
# Matches the devenv shell (devenv.nix exports the same GOFLAGS); CGO is set
# explicitly here so builds also work outside that shell.
export CGO_ENABLED=1
export GOFLAGS="-tags=sqlite_fts5"

# Always build into the shared user cache, never an inherited temporary cache.
# `env -u GOCACHE go env GOCACHE` reports the real default rather than echoing
# an override, so repeated shell entry remains a warm no-op.
export GOCACHE="$(env -u GOCACHE go env GOCACHE)"

mkdir -p "$bin_dir"

target_stale() {
  local output="$1"

  [[ -x "$output" ]] || return 0
  [[ -n "$(find "$repo_root" \
    \( -name .git -o -name .devenv -o -name .dev \) -prune -o \
    -type f \
    -newer "$output" -print -quit)" ]]
}

# Go's build cache makes an unchanged rebuild fast (warm sequential measured
# well under a second), so this always runs on shell entry rather than
# skipping fresh targets. Quiet on a warm success (one summary line); a cold
# run announces the build before it starts.
start="${EPOCHREALTIME:-$SECONDS.0}"

target_count=0
show_progress=0
while IFS= read -r go_mod; do
  module_dir="$(dirname "$go_mod")"
  cmd_dir="$module_dir/cmd"

  if [[ ! -d "$cmd_dir" ]]; then
    continue
  fi

  while IFS= read -r target_dir; do
    if [[ -z "$(find "$target_dir" -maxdepth 1 -name '*.go' -print -quit)" ]]; then
      continue
    fi
    name="$(basename "$target_dir")"
    output="$bin_dir/$name"

    target_count=$((target_count + 1))
    if target_stale "$output"; then
      show_progress=1
    fi
  done < <(find "$cmd_dir" -mindepth 1 -maxdepth 1 -type d | sort)
# Prune at any depth: .devenv holds Go module caches (root state dir, plus
# leftover per-module state dirs from older devenvs) whose
# third-party go.mod files are not ours to build; .dev is local build state.
done < <(find . \( -name .git -o -name .devenv -o -name .dev \) -prune -o -name go.mod -print | sort)

if [[ "$show_progress" -eq 1 ]]; then
  target_label="binaries"
  if [[ "$target_count" -eq 1 ]]; then
    target_label="binary"
  fi
  printf 'dev-bin: building %d %s...\n' "$target_count" "$target_label" >&2
fi

while IFS= read -r go_mod; do
  module_dir="$(dirname "$go_mod")"
  cmd_dir="$module_dir/cmd"

  if [[ ! -d "$cmd_dir" ]]; then
    continue
  fi

  while IFS= read -r target_dir; do
    if [[ -z "$(find "$target_dir" -maxdepth 1 -name '*.go' -print -quit)" ]]; then
      continue
    fi
    name="$(basename "$target_dir")"
    output="$bin_dir/$name"
    module_path="${module_dir#./}"

    log="$(mktemp)"
    if ! ( cd "$module_dir" && go build -o "$output" "./cmd/$name" ) >"$log" 2>&1; then
      printf 'building %s from %s/cmd/%s...\n' "$name" "$module_path" "$name"
      cat "$log"
      rm -f "$log"
      exit 1
    fi
    rm -f "$log"
  done < <(find "$cmd_dir" -mindepth 1 -maxdepth 1 -type d | sort)
done < <(find . \( -name .git -o -name .devenv -o -name .dev \) -prune -o -name go.mod -print | sort)

end="${EPOCHREALTIME:-$SECONDS.0}"
elapsed="$(awk -v s="$start" -v e="$end" 'BEGIN { printf "%.1f", e - s }')"
printf 'dev-bin: fresh (%ss)\n' "$elapsed"
