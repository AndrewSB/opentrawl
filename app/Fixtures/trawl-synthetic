#!/bin/sh
set -eu

# This helper has no archive access. Tests select its typed response with the
# final argument, then inspect its complete process boundary.
last=""
for argument do
  last="$argument"
done
case "$1:$2:$last" in
  __app:status:*)
    /usr/bin/printf '\002\000\000\000\010\001'
    ;;
  __app:sync:*)
    /usr/bin/printf '\002\000\000\000\010\001'
    ;;
  __app:search:partial)
    /usr/bin/printf '\004\000\000\000\010\002\040\024'
    ;;
  __app:search:failed)
    /usr/bin/printf '\004\000\000\000\010\003\040\024'
    ;;
  __app:search:*)
    /usr/bin/printf '\004\000\000\000\010\001\040\024'
    ;;
  __app:open:*)
    /usr/bin/printf '\002\000\000\000\010\003'
    ;;
  *)
    /usr/bin/printf 'unsupported synthetic command\n' >&2
    exit 2
    ;;
esac
