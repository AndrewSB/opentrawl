#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
usage: app/scripts/setup-release-credentials \
  [--notary-key FILE --notary-key-id ID --notary-issuer ID] \
  [--create-sparkle-key]

Creates and checks OpenTrawl's explicit local release credential store.

Pass a newly downloaded App Store Connect team API key once. The script moves
it into the private release directory and validates it with notarytool. An
individual API key cannot use notarytool.

Restore the Sparkle private key from backup on a replacement release Mac.
--create-sparkle-key is only safe before the first public release because
existing installations trust the current key.
EOF
  exit 2
}

source_notary_key=""
notary_key_id=""
notary_issuer=""
create_sparkle_key=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --notary-key) source_notary_key="${2:-}"; shift 2 ;;
    --notary-key-id) notary_key_id="${2:-}"; shift 2 ;;
    --notary-issuer) notary_issuer="${2:-}"; shift 2 ;;
    --create-sparkle-key) create_sparkle_key=1; shift ;;
    *) usage ;;
  esac
done

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$script_dir/../.." && pwd)"
release_config="${OPENTRAWL_RELEASE_CONFIG_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/opentrawl/release}"
notary_key="$release_config/app-store-connect-api-key.p8"
notary_key_id_file="$release_config/app-store-connect-key-id"
notary_issuer_file="$release_config/app-store-connect-issuer-id"
sparkle_private_key="$release_config/sparkle-ed25519-private-key"
public_key_file="$repo_root/app/Release/SparklePublicKey"

for command in mv openssl tail xcrun xxd; do
  command -v "$command" >/dev/null || {
    echo "setup-release-credentials: required command is missing: $command" >&2
    exit 1
  }
done

mkdir -p "$release_config"
chmod 700 "$release_config"

if [[ -n "$source_notary_key" || -n "$notary_key_id" || -n "$notary_issuer" ]]; then
  [[ -s "$source_notary_key" && -n "$notary_key_id" && -n "$notary_issuer" ]] || usage
  [[ "$notary_key_id" =~ ^[A-Za-z0-9]{10,}$ ]] || {
    echo "setup-release-credentials: invalid App Store Connect API key ID" >&2
    exit 1
  }
  [[ "$notary_issuer" =~ ^[0-9A-Fa-f-]{36}$ ]] || {
    echo "setup-release-credentials: invalid App Store Connect issuer ID" >&2
    exit 1
  }
  [[ ! -e "$notary_key" ]] || {
    echo "setup-release-credentials: refusing to replace existing notarisation key: $notary_key" >&2
    exit 1
  }
  xcrun notarytool history \
    --key "$source_notary_key" \
    --key-id "$notary_key_id" \
    --issuer "$notary_issuer" >/dev/null || {
      echo "setup-release-credentials: Apple rejected the downloaded API key; nothing was installed" >&2
      exit 1
    }
  mv "$source_notary_key" "$notary_key"
  chmod 600 "$notary_key"
  (umask 177 && printf '%s\n' "$notary_key_id" > "$notary_key_id_file")
  (umask 177 && printf '%s\n' "$notary_issuer" > "$notary_issuer_file")
fi

[[ -s "$notary_key" && -s "$notary_key_id_file" && -s "$notary_issuer_file" ]] || {
  echo "setup-release-credentials: App Store Connect team API key is not installed" >&2
  echo "Download it once, then pass --notary-key, --notary-key-id and --notary-issuer." >&2
  exit 1
}
chmod 600 "$notary_key" "$notary_key_id_file" "$notary_issuer_file"
notary_key_id="$(tr -d '[:space:]' < "$notary_key_id_file")"
notary_issuer="$(tr -d '[:space:]' < "$notary_issuer_file")"
xcrun notarytool history \
  --key "$notary_key" \
  --key-id "$notary_key_id" \
  --issuer "$notary_issuer" >/dev/null

if [[ ! -s "$sparkle_private_key" ]]; then
  if [[ "$create_sparkle_key" -ne 1 ]]; then
    echo "setup-release-credentials: missing Sparkle private key: $sparkle_private_key" >&2
    echo "Restore it from backup, or before the first public release rerun with --create-sparkle-key." >&2
    exit 1
  fi
  (umask 177 && openssl rand -base64 32 > "$sparkle_private_key")
fi
chmod 600 "$sparkle_private_key"

seed_hex="$(openssl base64 -d -A -in "$sparkle_private_key" | xxd -p -c 256)"
[[ "${#seed_hex}" -eq 64 ]] || {
  echo "setup-release-credentials: Sparkle private key must be base64 for exactly 32 bytes" >&2
  exit 1
}
private_public_key="$({
  printf '302e020100300506032b657004220420%s' "$seed_hex" | xxd -r -p
} | openssl pkey -inform DER -pubout -outform DER 2>/dev/null | tail -c 32 | openssl base64 -A)"
repository_public_key="$(tr -d '[:space:]' < "$public_key_file")"
if [[ "$private_public_key" != "$repository_public_key" ]]; then
  echo "setup-release-credentials: Sparkle key does not match app/Release/SparklePublicKey" >&2
  echo "Public key for this private key: $private_public_key" >&2
  exit 1
fi

echo "OpenTrawl release credentials are ready"
echo "App Store Connect API key: $notary_key"
echo "Sparkle private key: $sparkle_private_key"
